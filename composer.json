{
    "name": "mfrederico/halfbaked",
    "description": "Prototype with LLMs. Bake into production PHP. A pipeline engine that lets you rapid-prototype API integrations with specialist LLMs, then compile working steps into deterministic PHP code.",
    "type": "library",
    "license": "MIT",
    "keywords": ["llm", "pipeline", "code-generation", "ollama", "api", "prototype", "bake"],
    "authors": [
        {
            "name": "M. Frederico",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "HalfBaked\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HalfBaked\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/halfbaked"],
    "minimum-stability": "stable"
}
