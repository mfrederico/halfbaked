// =====================================================================
// File Discovery
// =====================================================================

/**
 * Auto-discover relevant files based on task keywords.
 */
function autoDiscover(string $projectPath, string $task): array
{
    $files = [];

    // Extract keywords from task
    $keywords = extractKeywords($task);

    // Scan for PHP files matching keywords
    $allFiles = scanPhpFiles($projectPath, 200);

    // Score each file by keyword relevance
    $scored = [];
    foreach ($allFiles as $file) {
        $rel = strtolower(str_replace($projectPath . '/', '', $file));
        $score = 0;

        foreach ($keywords as $kw) {
            $kw = strtolower($kw);
            // Filename match
            if (str_contains($rel, $kw)) {
                $score += 10;
            }
            // Content match (first 50 lines only for speed)
            $head = implode("\n", array_slice(file($file) ?: [], 0, 50));
            if (stripos($head, $kw) !== false) {
                $score += 3;
            }
        }

        // Boost common patterns
        if (str_contains($rel, 'service')) $score += 2;
        if (str_contains($rel, 'controller') || str_contains($rel, 'control')) $score += 2;
        if (str_contains($rel, 'model')) $score += 1;

        // De-prioritize tests and vendor
        if (str_contains($rel, 'test')) $score -= 5;
        if (str_contains($rel, 'vendor')) $score -= 100;

        if ($score > 0) {
            $scored[$file] = $score;
        }
    }

    arsort($scored);

    // Return top 8 most relevant
    return array_slice(array_keys($scored), 0, 8);
}

/**
 * Extract meaningful keywords from a task description.
 */
function extractKeywords(string $task): array
{
    // Remove stopwords
    $stop = ['a','an','the','and','or','to','for','of','in','on','with','that','this','is','are',
             'was','were','be','been','being','have','has','had','do','does','did','will','would',
             'could','should','can','may','might','must','shall','add','create','write','build',
             'make','implement','generate','update','fix','refactor','new'];

    $words = preg_split('/[\s,.:;!?]+/', strtolower($task));
    $keywords = [];
    foreach ($words as $word) {
        $word = trim($word, '"\'()[]{}');
        if (strlen($word) >= 3 && !in_array($word, $stop)) {
            $keywords[] = $word;
        }
    }

    return array_unique($keywords);
}

/**
 * Scan directory for PHP files (excluding vendor, node_modules, .git).
 */
function scanPhpFiles(string $dir, int $limit = 50): array
{
    $files = [];
    $skip = ['vendor', 'node_modules', '.git', '.svn', 'cache', 'storage', 'logs'];

    $iter = new \RecursiveIteratorIterator(
        new \RecursiveCallbackFilterIterator(
            new \RecursiveDirectoryIterator($dir, \FilesystemIterator::SKIP_DOTS),
            function ($current, $key, $iterator) use ($skip) {
                if ($current->isDir()) {
                    return !in_array($current->getFilename(), $skip);
                }
                return $current->getExtension() === 'php';
            }
        )
    );

    foreach ($iter as $file) {
        if ($file->isFile() && $file->getExtension() === 'php') {
            $files[] = $file->getPathname();
            if (count($files) >= $limit) break;
        }
    }

    return $files;
}

/**
 * Build a context block from file contents, respecting max size.
 */
function buildContext(array $files, string $basePath, int $maxChars): string
{
    $context = '';
    $remaining = $maxChars;

    foreach ($files as $file) {
        if ($remaining <= 0) break;

        $rel = str_replace($basePath . '/', '', $file);
        $content = file_get_contents($file);
        if ($content === false) continue;

        // Truncate large files
        if (strlen($content) > 3000) {
            $content = substr($content, 0, 3000) . "\n// ... truncated ...";
        }

        $block = "### {$rel}\n```php\n{$content}\n```\n\n";

        if (strlen($block) > $remaining) {
            break;
        }

        $context .= $block;
        $remaining -= strlen($block);
    }

    return $context;
}
